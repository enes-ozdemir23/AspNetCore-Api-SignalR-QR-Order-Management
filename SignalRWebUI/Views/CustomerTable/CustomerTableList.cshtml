@model List<ResultMenuTableDto>
@{
    Layout = null;
    string color ="";
    string status ="";
    string icon ="";

}

<!DOCTYPE html>
<html>

<style>
    .widgetfalse { /* FALSE = BOŞ */
    width: 200px;
    height: 100px;
    background-color: #6B8E73; /* YEŞİL */
    display: flex;
    align-items: center;
    border-radius: 10px;
    color: white;
    font-family: Arial, sans-serif;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
    }

    .widgettrue { /* TRUE = DOLU */
    width: 200px;
    height: 100px;
    background-color: #5D6D7E; /* KIRMIZI */
    display: flex;
    align-items: center;
    border-radius: 10px;
    color: white;
    font-family: Arial, sans-serif;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
    }

    /* Ortak icon yapısı */
    .widget-icon {
    width: 40px;
    height: 40px;
    background-color: white;
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    margin-left: 10px;
    }

    /* Boş masa icon rengi */
    .widgetfalse .widget-icon i {
    font-size: 24px;
    color: #6B8E73;
    }

    /* Dolu masa icon rengi */
    .widgettrue .widget-icon i {
    font-size: 24px;
    color: #5D6D7E;
    }


    .widget-text {
    margin-left: 20px;
    }

    .widget-text h3 {
    margin: 0;
    font-size: 18px;
    }

    .widget-text p {
    margin: 0;
    font-size: 14px;
    }
</style>


<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

@await Component.InvokeAsync("_UILayoutHeadComponentPartial")

<body class="sub_page">

    @await Component.InvokeAsync("_MenuNavbarComponentPartial")
    <br />
    <br />

    <div class="container-fluid">
        <div class="row px-xl-5">
            <div class="col-12">
                <nav class="breadcrumb bg-dark mb-30">
                    <a class="breadcrumb-item text-white" href="/Default/Index/">Ana Sayfa</a>
                    <a class="breadcrumb-item text-white" href="/Menu/Index/">Masa Listesi</a>
                    <span class="breadcrumb-item active">Masa Seçimi Yapınız</span>
                </nav>
            </div>
        </div>
    </div>

    <div class="container-fluid">
        <div class="row px-xl-5" style="margin-right:10px">
            @foreach (var item in Model)
            {
                if (item.Status == false)
                {
                    color = "widgetfalse";
                    status = "Masa Boş";
                    icon = "widget-iconfalse";
                }
                if (item.Status == true)
                {
                    color = "widgettrue";
                    status = "Masa Dolu";
                    icon = "widget-icontrue";
                }
                <div class="col-md-3 mb-4">
                    <div class="@color">
                        @if (item.Status == true)
                        {
                            <div class="widget-icon">
                                <a href="/Baskets/Index/@item.MenuTableID"><i class="fa-solid fa-circle-dollar-to-slot"></i></a>
                            </div>

                            
                        }
                        else
                        {
                            <div class="widget-icon">
                                <a href="/Menu/Index/@item.MenuTableID"><i class="fas fa-chair"></i></a> <!-- Masa ikonu -->
                            </div>
                        }

                    <div class="widget-text">
                        <h3>@item.Name</h3>
                        <p>@status</p>
                    </div>
                </div>
                </div>
            }

            </div>
        </div>

  


    @await Component.InvokeAsync("_UILayoutFooterComponentPartial")


    @await Component.InvokeAsync("_UILayoutScriptComponentPartial")


</body>

</html>


